# ── Required ──────────────────────────────────────────────
ASSEMBLYAI_API_KEY=
API_FOOTBALL_KEY=

# ── Azure (API + worker + ingest when using cloud storage) ──
# If AZURE_STORAGE_CONNECTION_STRING is set, STORAGE_BACKEND defaults to azure
# (queue, table, blob). Use STORAGE_BACKEND=local to force disk + in-memory job store.
# AZURE_STORAGE_CONNECTION_STRING=
# STORAGE_BACKEND=local

# ── Optional (legacy excitement pipeline) ─────────────────
# Azure OpenAI — used by the older LLM excitement scoring stage
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=

# OpenAI fallback — used when Azure settings are not provided
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
